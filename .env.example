# OpenAI key for src/extractor.py
OPENAI_API_KEY=your_openai_api_key_here

# API endpoint and token for src/uploader.py
YRITYSDATA_API_URL=
YRITYSDATA_API_TOKEN=your_api_token_here

# Downloader defaults used by docker-compose
GAZETTE_YEAR=2024
GAZETTE_NUMBER=001

# Set to 1 to skip LLM extraction (CI smoke mode)
EXTRACTOR_DRY_RUN=0
